#use std_core::primitive::array::Array;
#use std_core::primitive::i32::i32;

#struct ParsedSourceFile : Type[0] {
    exit_code : i32,
}

#fn parse_source : (source : Array u8 1024i32) -> ParsedSourceFile #with IO {
    #let exit_code : i32 <- parse_exit_code source;
    ParsedSourceFile { exit_code = exit_code }
}
