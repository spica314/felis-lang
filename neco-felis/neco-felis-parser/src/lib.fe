                        #let is_ident_part_ref : i32 = 0i32;
    #letref #excl is_ident_part_ref : &^ i32 #borrow is_ident_part_ref;
                        mark_ident_part ident_byte is_ident_part_ref;
                        #if i32_eq (is_ident_part_ref .> get) 1i32 {
                            ident_end_ref .> set (i32_add (ident_end_ref .> get) 1i32);
                        } #else {
                            #break;
                        };
                    };
                    #let token_payload : FelisTokenPayload = FelisTokenPayload {
                        value = i32_sub (ident_end_ref .> get) ident_start,
                        start = ident_start,
                        end = ident_end_ref .> get
                    };
                    #let token : FelisToken = FelisToken::ident token_payload;
                    parse_felis_token token source_ref parse_state_ref stmt_tag_ref stmt_value_ref stmt_start_ref stmt_end_ref stmt_name_start_ref stmt_name_end_ref stmt_expr_start_ref stmt_expr_end_ref number_byte_ref let_name_start_ref let_name_end_ref expr_start_ref expr_end_ref stmt_count_ref;
                    source_index_ref .> set (ident_end_ref .> get);
                } #else {
                    #let token_payload : FelisTokenPayload = FelisTokenPayload {
                        value = i32_from_u8 byte,
                        start = source_index_ref .> get,
                        end = i32_add (source_index_ref .> get) 1i32
                    };
                    #let token : FelisToken = FelisToken::byte token_payload;
                    parse_felis_token token source_ref parse_state_ref stmt_tag_ref stmt_value_ref stmt_start_ref stmt_end_ref stmt_name_start_ref stmt_name_end_ref stmt_expr_start_ref stmt_expr_end_ref number_byte_ref let_name_start_ref let_name_end_ref expr_start_ref expr_end_ref stmt_count_ref;
                    source_index_ref .> set (i32_add (source_index_ref .> get) 1i32);
                };
            };
        } #else {
            #let is_ident_start_ref : i32 = 0i32;
    #letref #excl is_ident_start_ref : &^ i32 #borrow is_ident_start_ref;
            mark_ident_start byte is_ident_start_ref;
            #if i32_eq (is_ident_start_ref .> get) 1i32 {
                #let ident_start : i32 = source_index_ref .> get;
                #let ident_end_ref : i32 = ident_start;
    #letref #excl ident_end_ref : &^ i32 #borrow ident_end_ref;
                #loop {
                    #if i32_gte (ident_end_ref .> get) source_len {
                        #break;
                    };
                    #let ident_byte : u8 = dyn_array_get_u8 source_ref (ident_end_ref .> get);
                    #let is_ident_part_ref : i32 = 0i32;
    #letref #excl is_ident_part_ref : &^ i32 #borrow is_ident_part_ref;
                    mark_ident_part ident_byte is_ident_part_ref;
                    #if i32_eq (is_ident_part_ref .> get) 1i32 {
                        ident_end_ref .> set (i32_add (ident_end_ref .> get) 1i32);
                    } #else {
                        #break;
                    };
                };
                #let token_payload : FelisTokenPayload = FelisTokenPayload {
                    value = i32_sub (ident_end_ref .> get) ident_start,
                    start = ident_start,
                    end = ident_end_ref .> get
                };
                #let token : FelisToken = FelisToken::ident token_payload;
                parse_felis_token token source_ref parse_state_ref stmt_tag_ref stmt_value_ref stmt_start_ref stmt_end_ref stmt_name_start_ref stmt_name_end_ref stmt_expr_start_ref stmt_expr_end_ref number_byte_ref let_name_start_ref let_name_end_ref expr_start_ref expr_end_ref stmt_count_ref;
