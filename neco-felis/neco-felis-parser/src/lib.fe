#pub #proc parse_felis_source_tokens : (source : String) -> (token_tag_ref : DynArray i32) -> (token_value_ref : DynArray i32) -> (token_start_ref : DynArray i32) -> (token_end_ref : DynArray i32) -> (token_count_ref : &^ i32) -> () {
    #let source_ref : DynArray u8 = string_as_dyn_array source;
    #let source_len : i32 = string_len source;
    #let source_index_ref : i32 = 0i32;
    #letref #excl source_index_ref : &^ i32 #borrow source_index_ref;
    token_count_ref .> set 0i32;
    #loop {
        #if i32_gte (source_index_ref .> get) source_len {
            #break;
        };
        #let byte : u8 = dyn_array_get_u8 source_ref (source_index_ref .> get);
        #let is_whitespace_ref : i32 = 0i32;
        #letref #excl is_whitespace_ref : &^ i32 #borrow is_whitespace_ref;
        mark_whitespace byte is_whitespace_ref;
        #if i32_eq (is_whitespace_ref .> get) 1i32 {
            source_index_ref .> set (i32_add (source_index_ref .> get) 1i32);
        } #else #if u8_eq byte '/' {
            #let next_index : i32 = i32_add (source_index_ref .> get) 1i32;
            #if i32_lt next_index source_len {
                #let next_byte : u8 = dyn_array_get_u8 source_ref next_index;
                #if u8_eq next_byte '/' {
                    source_index_ref .> set (i32_add next_index 1i32);
                    #loop {
                        #if i32_gte (source_index_ref .> get) source_len {
                            #break;
                        };
                        #let comment_byte : u8 = dyn_array_get_u8 source_ref (source_index_ref .> get);
                        #if u8_eq comment_byte '\n' {
                            #break;
                        };
                        source_index_ref .> set (i32_add (source_index_ref .> get) 1i32);
                    };
                } #else #if u8_eq next_byte '*' {
                    source_index_ref .> set (i32_add next_index 1i32);
                    #loop {
                        #if i32_gte (source_index_ref .> get) source_len {
                            #break;
                        };
                        #let comment_byte : u8 = dyn_array_get_u8 source_ref (source_index_ref .> get);
                        #let comment_next_index : i32 = i32_add (source_index_ref .> get) 1i32;
                        #if u8_eq comment_byte '*' {
                            #if i32_lt comment_next_index source_len {
                                #let comment_next_byte : u8 = dyn_array_get_u8 source_ref comment_next_index;
                                #if u8_eq comment_next_byte '/' {
                                    source_index_ref .> set (i32_add comment_next_index 1i32);
                                    #break;
                                };
                            };
                        };
                        source_index_ref .> set comment_next_index;
                    };
                } #else {
                    #let token_payload : FelisTokenPayload = FelisTokenPayload {
                        value = i32_from_u8 byte,
                        start = source_index_ref .> get,
                        end = i32_add (source_index_ref .> get) 1i32
                    };
                    append_parsed_felis_token 0i32 token_payload token_tag_ref token_value_ref token_start_ref token_end_ref token_count_ref;
                    source_index_ref .> set (i32_add (source_index_ref .> get) 1i32);
                };
            } #else {
                #let token_payload : FelisTokenPayload = FelisTokenPayload {
                    value = i32_from_u8 byte,
                    start = source_index_ref .> get,
                    end = i32_add (source_index_ref .> get) 1i32
                };
                append_parsed_felis_token 0i32 token_payload token_tag_ref token_value_ref token_start_ref token_end_ref token_count_ref;
                source_index_ref .> set (i32_add (source_index_ref .> get) 1i32);
            };
        } #else #if u8_eq byte '#' {
            #let keyword_start : i32 = i32_add (source_index_ref .> get) 1i32;
            #let keyword_code_ref : i32 = 0i32;
            #letref #excl keyword_code_ref : &^ i32 #borrow keyword_code_ref;
            #if i32_lt keyword_start source_len {
                #let keyword_start_byte : u8 = dyn_array_get_u8 source_ref keyword_start;
                #let is_keyword_start_ref : i32 = 0i32;
                #letref #excl is_keyword_start_ref : &^ i32 #borrow is_keyword_start_ref;
                mark_ident_start keyword_start_byte is_keyword_start_ref;
                #if i32_eq (is_keyword_start_ref .> get) 1i32 {
                    #let keyword_end_ref : i32 = keyword_start;
                    #letref #excl keyword_end_ref : &^ i32 #borrow keyword_end_ref;
                    #loop {
                        #if i32_gte (keyword_end_ref .> get) source_len {
                            #break;
                        };
                        #let keyword_byte : u8 = dyn_array_get_u8 source_ref (keyword_end_ref .> get);
                        #let is_keyword_part_ref : i32 = 0i32;
