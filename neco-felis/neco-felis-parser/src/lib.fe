            #if u8_gt byte '/' {
                #let number_start : i32 = source_index_ref .> get;
                #let number_end_ref : i32 = number_start;
    #letref #excl number_end_ref : &^ i32 #borrow number_end_ref;
                #let parsed_number_ref : i32 = 0i32;
    #letref #excl parsed_number_ref : &^ i32 #borrow parsed_number_ref;
                dyn_array_set_u8 number_byte_ref 0x00i32 0x00u8;
                #loop {
                    #if i32_gte (number_end_ref .> get) source_len {
                        #break;
                    };
                    #let number_byte : u8 = dyn_array_get_u8 source_ref (number_end_ref .> get);
                    #if u8_lt number_byte ':' {
                        #if u8_gt number_byte '/' {
                            #let next_number : i32 = accumulate_decimal_i32 (parsed_number_ref .> get) (i32_from_u8 number_byte);
                            parsed_number_ref .> set next_number;
                            #let current_number_byte : u8 = dyn_array_get_u8 number_byte_ref 0x00i32;
                            #let next_number_byte : u8 = accumulate_decimal_u8 current_number_byte number_byte;
                            dyn_array_set_u8 number_byte_ref 0x00i32 next_number_byte;
                            number_end_ref .> set (i32_add (number_end_ref .> get) 1i32);
                        } #else {
                            #break;
                        };
                    } #else {
                        #break;
                    };
                };
                #let token_payload : FelisTokenPayload = FelisTokenPayload {
                    value = parsed_number_ref .> get,
                    start = number_start,
                    end = number_end_ref .> get
                };
                #let token : FelisToken = FelisToken::int_literal token_payload;
                parse_felis_token token source_ref parse_state_ref stmt_tag_ref stmt_value_ref stmt_start_ref stmt_end_ref stmt_name_start_ref stmt_name_end_ref stmt_expr_start_ref stmt_expr_end_ref number_byte_ref let_name_start_ref let_name_end_ref expr_start_ref expr_end_ref stmt_count_ref;
