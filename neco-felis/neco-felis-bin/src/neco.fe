    #let _ @^ expr_rhs_ref : DynArray = DynArray::dyn_array expr_rhs_raw_ref 0x80i32 0i32;
    #let _ @^ expr_count_ref : i32 = 0i32;
    parse_felis_source_tokens source_ref source_len token_tag_ref token_value_ref token_start_ref token_end_ref token_count_ref;
    parse_felis_source source_ref source_len stmt_tag_ref stmt_value_ref stmt_start_ref stmt_end_ref stmt_name_start_ref stmt_name_end_ref stmt_expr_start_ref stmt_expr_end_ref number_byte_ref stmt_count_ref;
    #let _ @ output_path_ref : & Array u8 = "a.out";
    #let output_path_bytes_ref : & Array u8 = output_path_ref .> as_bytes;
    #let fd : FileDescriptor <- IO::open output_path_bytes_ref 0x241i32 0x1edi32;
    #let elf_raw_ref : &^ RawArray u8 <- IO::raw_array_new u8 0x1040i32;
    #let _ @^ elf_ref : DynArray = DynArray::dyn_array elf_raw_ref 0x1040i32 0i32;
    #let elf_bytes_ref : RawArray u8 = dyn_array_raw_u8 elf_ref;
    fill_u8 elf_bytes_ref 0x00u8;
