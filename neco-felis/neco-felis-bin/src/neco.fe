    #let _ @^ emit_u8_state_ref : DynArray = DynArray::dyn_array emit_u8_state_raw_ref 0x02i32 0i32;
    #let _ @^ stmt_count_ref : i32 = 0i32;
    #let token_tag_raw_ref : &^ RawArray i32 <- IO::raw_array_new i32 0x80i32;
