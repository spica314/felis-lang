#use std_core::primitive::reference::ref_get;
#use std_core::io::IO;
#use std_core::primitive::array::ArrayVL;
#use std_core::primitive::vec::Vec;
#use std_core::primitive::array::array_set;
#use std_core::primitive::i32::i32_add;
#use std_core::primitive::i32::i32_eq;
#use std_core::primitive::i32::i32_from_u8;
#use std_core::string::String;
#use std_core::string::mark_string_eq;
#use std_core::string::mark_string_span_eq;
#use std_core::string::string_copy_from_vec_range_into;
#use std_core::string::string_from_vec;
#use std_core::string::string_from_arrayvl_parts;
#use std_core::string::string_get_u8;
#use std_core::string::string_len;
#use std_core::string::string_push_u8_unchecked;
#use std_core::string::string_set_u8;
#use std_core::string::string_with_len;

#entrypoint main;

#fn main : () #with IO {
    #let arrayvl : ArrayVL u8 <- IO::arrayvl_new u8 8i32;
    #letref #excl arrayvl_ref : &^ ArrayVL u8 #borrow arrayvl;
    array_set arrayvl_ref 0i32 40u8;
    array_set arrayvl_ref 1i32 2u8;
    #let array : Vec u8 = Vec::vec u8 arrayvl 2i64;
    #let string : String = string_from_vec array;
    #let first : u8 <- string_get_u8 string 0i32;
    #let len : i32 = string_len string;
    #let first_code : i32 = i32_from_u8 first;
    #let code : i32 = i32_add first_code len;

    #let source_arrayvl : ArrayVL u8 <- IO::arrayvl_new u8 7i32;
    #letref #excl source_arrayvl_ref : &^ ArrayVL u8 #borrow source_arrayvl;
    array_set source_arrayvl_ref 0i32 'l';
    array_set source_arrayvl_ref 1i32 'e';
    array_set source_arrayvl_ref 2i32 't';
    array_set source_arrayvl_ref 3i32 ' ';
    array_set source_arrayvl_ref 4i32 'f';
    array_set source_arrayvl_ref 5i32 'o';
    array_set source_arrayvl_ref 6i32 'o';
    #let source : Vec u8 = Vec::vec u8 source_arrayvl 7i64;
    #let copied_arrayvl : ArrayVL u8 <- IO::arrayvl_new u8 3i32;
    #letref #excl copied_arrayvl_ref : &^ ArrayVL u8 #borrow copied_arrayvl;
    #let copied_dest : String = string_from_arrayvl_parts copied_arrayvl 3i32 0i32;
    string_copy_from_vec_range_into source 4i32 7i32 copied_dest;
    #let copied_name : String = string_with_len copied_dest 3i32;

    #let name_arrayvl : ArrayVL u8 <- IO::arrayvl_new u8 4i32;
    #letref #excl name_arrayvl_ref : &^ ArrayVL u8 #borrow name_arrayvl;
    #let empty_name : String = string_from_arrayvl_parts name_arrayvl 4i32 0i32;
    #let name_len_ref : i32 = 0i32;
    #letref #excl name_len_ref : &^ i32 #borrow name_len_ref;
    string_push_u8_unchecked empty_name name_len_ref 'f';
    string_push_u8_unchecked empty_name name_len_ref 'x';
    string_set_u8 empty_name 1i32 'o';
    string_push_u8_unchecked empty_name name_len_ref 'o';
    #let name_len : i32 <- ref_get i32 name_len_ref;
    #let built_name : String = string_with_len empty_name name_len;

    #let eq_ref : i32 = 0i32;
    #letref #excl eq_ref : &^ i32 #borrow eq_ref;
    mark_string_eq copied_name built_name eq_ref;
    #let span_eq_ref : i32 = 0i32;
    #letref #excl span_eq_ref : &^ i32 #borrow span_eq_ref;
    mark_string_span_eq built_name source 4i32 7i32 span_eq_ref;

    #let exit_code : i32 = code;
    #let eq : i32 <- ref_get i32 eq_ref;
    #if i32_eq eq 0i32 {
        #let _ : () <- IO::sys_exit 1i32;
    };
    #let span_eq : i32 <- ref_get i32 span_eq_ref;
    #if i32_eq span_eq 0i32 {
        #let _ : () <- IO::sys_exit 2i32;
    };
    #let _ : () <- IO::sys_exit exit_code;
    ()
}
