#use std_core::io::IO;
#use std_core::ptx::PTX;
#use std_core::ptx::ctaid_x;
#use std_core::ptx::tid_x;
#use std_core::primitive::array::ArrayVL;
#use std_core::primitive::array::ArrayVLPTX;
#use std_core::primitive::array::array_get;
#use std_core::primitive::array::array_set;
#use std_core::primitive::f32::f32;
#use std_core::primitive::f32::f32_add;
#use std_core::primitive::f32::f32_div;
#use std_core::primitive::f32::f32_from_i32;
#use std_core::primitive::f32::f32_mul;
#use std_core::primitive::f32::f32_sqrt;
#use std_core::primitive::f32::f32_sub;
#use std_core::primitive::i32::i32;
#use std_core::primitive::i32::i32_add;
#use std_core::primitive::i32::i32_eq;
#use std_core::primitive::i32::i32_from_f32;
#use std_core::primitive::i32::i32_mul;
#use std_core::primitive::i64::i64;
#use std_core::primitive::reference::ref_get;
#use std_core::primitive::reference::ref_set_ptx;
#use std_core::primitive::u8::u8;

#fn render_like_kernel : (framebuffer : ArrayVLPTX i32) -> () #with PTX {
    #let x : i32 = ctaid_x;
    #let y : i32 = tid_x;
    #let dir_x : f32 = f32_add -1.7733333f32 (f32_mul (f32_from_i32 x) 0.008888889f32);
    #let dir_y : f32 = f32_add 0.9955556f32 (f32_mul (f32_from_i32 y) -0.008888889f32);
    #let dir_len : f32 = f32_sqrt (f32_add (f32_add (f32_mul dir_x dir_x) (f32_mul dir_y dir_y)) 1.0f32);
    #let unit_y : f32 = f32_div dir_y dir_len;
    #let a : f32 = f32_mul 0.5f32 (f32_add unit_y 1.0f32);
    #let white_weight : f32 = f32_sub 1.0f32 a;
    #let red : f32 = f32_add white_weight (f32_mul a 0.5f32);
    #let green : f32 = f32_add white_weight (f32_mul a 0.7f32);
    #let base : i32 = i32_mul (i32_add (i32_mul y 400i32) x) 3i32;
    ref_set_ptx i32 framebuffer base (i32_from_f32 (f32_mul 255.999f32 red));
    ref_set_ptx i32 framebuffer (i32_add base 1i32) (i32_from_f32 (f32_mul 255.999f32 green));
    ref_set_ptx i32 framebuffer (i32_add base 2i32) 255i32;
    ()
}

#compile_ptx render_like_kernel #to render_like_kernel_ptx;

#entrypoint main;

#fn main : () #with IO {
    #let image_width : i32 = 400i32;
    #let image_height : i32 = 225i32;
    #let framebuffer_len : i32 = i32_mul (i32_mul image_width image_height) 3i32;
    #let init_result : i32 <- IO::cu_init 0i32;
    #let device : i32 = 0i32;
    #letref #excl device : &^ i32 #borrow device;
    #let device_result : i32 <- IO::cu_device_get device 0i32;
    #let device_value : i32 <- ref_get i32 device;
    #let ctx : i64 = 0i64;
    #letref #excl ctx : &^ i64 #borrow ctx;
    #let ctx_result : i32 <- IO::cu_ctx_create_v2 ctx 0i32 device_value;
    #let module : i64 = 0i64;
    #letref #excl module : &^ i64 #borrow module;
    #let ptx : & ArrayVL u8 = render_like_kernel_ptx;
    #let module_result : i32 <- IO::cu_module_load_data module ptx;
    #let module_value : i64 <- ref_get i64 module;
    #let function : i64 = 0i64;
    #letref #excl function : &^ i64 #borrow function;
    #let function_result : i32 <- IO::cu_module_get_function function module_value "render_like_kernel";
    #let function_value : i64 <- ref_get i64 function;
    #let host_array : ArrayVL i32 <- IO::arrayvl_new i32 framebuffer_len;
    #letref #excl host_array_ref : &^ ArrayVL i32 #borrow host_array;
    array_set host_array_ref 0i32 0i32;
    array_set host_array_ref 1i32 0i32;
    array_set host_array_ref 2i32 0i32;
    #let device_array : ArrayVLPTX i32 <- IO::arrayvlptx_new i32 framebuffer_len;
    #let copy_to_result : i32 <- IO::arrayvl_to_ptx i32 host_array device_array framebuffer_len;
    #let launch_result : i32 <- IO::cu_launch_kernel function_value device_array image_width 1i32 1i32 image_height 1i32 1i32 0i32 0i64;
    #let copy_from_result : i32 <- IO::arrayvl_from_ptx i32 device_array host_array framebuffer_len;
    #let blue : i32 = array_get host_array 2i32;
    #if i32_eq blue 255i32 {
        #let _ : () <- IO::exit 0i32;
    } #else {
        #let _ : () <- IO::exit 1i32;
    };
    ()
}
