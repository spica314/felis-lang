#use std_core::io::IO;
#use std_core::primitive::u8::u8;

#entrypoint main;

#fn main : () #with IO {
    #let stdout <- IO::stdout;
    #let _ @^ bytes_ref <- IO::array_new u8 0x2i32;
    bytes_ref .> set 0x0i32 0x41u8;
    bytes_ref .> set 0x1i32 0xau8;
    #let _ <- IO::write stdout bytes_ref 0x2i32;
    ()
}
